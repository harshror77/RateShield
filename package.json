{
  "name": "rate-limiter-service",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/dashboard",
    "packages/sdk",
    "packages/shared"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:dashboard": "npm run dev --workspace=apps/dashboard",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:dashboard\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}